---
import PostItem from '@/components/post/PostItem.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getPostsGroupedByYear } from '@/lib/posts';

const postsByYear = await getPostsGroupedByYear();
const hasPosts = postsByYear.length > 0;
---

<BaseLayout title="Archive" description="전체 글 목록">
  <section
    class="mx-auto w-full max-w-4xl space-y-10 px-2 lg:px-4"
    aria-label="Archive"
  >
    {
      hasPosts ? (
        postsByYear.map((group) => (
          <section class="space-y-3" aria-labelledby={`y-${group.year}`}>
            <div class="sticky top-16 z-20 -mx-4 px-4 py-2 backdrop-blur">
              <div class="divider divider-start">
                <h2
                  id={`y-${group.year}`}
                  class="text-sm font-semibold tracking-wide"
                >
                  {group.year}
                </h2>
              </div>
            </div>
            {group.posts.map((post) => (
              <ul>
                <PostItem post={post} />
              </ul>
            ))}
          </section>
        ))
      ) : (
        <p class="text-base-content/60 mt-8 text-center text-sm">
          작성된 글이 없습니다.
        </p>
      )
    }
  </section>
</BaseLayout>
