---
import PostItem from '@/components/post/PostItem.astro';
import { siteConfig } from '@/config';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getHomePosts, getPosts } from '@/lib/posts';

const totalCount = (await getPosts()).length;

const homePosts = await getHomePosts();
---

<BaseLayout title={siteConfig.name} description={siteConfig.description}>
  <section class="mx-auto w-full max-w-4xl px-2 lg:px-4">
    {homePosts.map((post) => <PostItem post={post} />)}
    <footer class="my-8 md:pt-8">
      <a
        href="/archive"
        class="text-accent inline-flex items-center gap-1.5 font-mono text-sm tracking-wide no-underline transition-colors duration-200"
      >
        All {totalCount} Posts →
      </a>
    </footer>
  </section>   
</BaseLayout> 
                                                                                     