---
import profile from '@/assets/images/avatar.png';
import { Image } from 'astro:assets';
---

<figure class="m-0 size-10 shrink-0">
  <Image
    alt="문지웅 프로필 이미지"
    src={profile}
    width={40}
    height={40}
    densities={[1, 2]}
    loading="eager"
    class="block size-full rounded-full object-cover"
  />
</figure>
