---
/**
 * 검색 버튼 – 모바일 전용 (sm 이상에서는 ⌘K 사용)
 * search:open CustomEvent 를 dispatch → search-modal.ts 에서 수신
 */
import SearchIcon from '@/icons/search.svg';
---

<button
  type="button"
  data-search-open
  aria-label="검색 (Ctrl 또는 ⌘ + K)"
  class="text-base-content/40 hover:text-base-content focus-visible:ring-primary/40 flex size-9 items-center justify-center rounded-full transition-colors duration-200 focus-visible:ring-2 focus-visible:outline-none lg:hidden"
>
  <SearchIcon class="size-5" />
</button>

<script>
  import { onPageReady } from '@/lib/lifecycle';

  function bindSearchButton(): void {
    document
      .querySelector('[data-search-open]')
      ?.addEventListener('click', () => {
        window.dispatchEvent(new CustomEvent('search:open'));
      });
  }

  onPageReady(bindSearchButton);
</script>
