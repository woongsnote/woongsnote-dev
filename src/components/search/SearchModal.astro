---
/**
 * 검색 모달 – native <dialog> + daisyUI modal
 *
 * - ESC 닫기: <dialog> 네이티브
 * - 배경 클릭 닫기: <form method="dialog"> 네이티브
 * - ⌘K / Ctrl+K: search-modal.ts 에서 처리
 * - 모바일 닫기 버튼: data-search-close
 * - ↑↓ Enter 키보드 탐색: search-modal.ts 에서 처리
 */
---

<dialog data-search-modal class="modal">
  <div class="modal-box max-w-2xl p-0">
    <!-- 검색 입력 -->
    <div class="border-base-300 flex items-center gap-2 border-b p-3">
      <input
        type="search"
        placeholder="검색… (⌘K / Ctrl+K)"
        class="input input-ghost w-full focus:outline-none"
        data-search-input
      />
      <button
        type="button"
        data-search-close
        aria-label="닫기"
        class="btn btn-ghost btn-sm sm:hidden"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="size-4"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path d="M18 6 6 18M6 6l12 12"></path>
        </svg>
      </button>
    </div>

    <!-- 결과 목록 -->
    <div class="max-h-[60vh] overflow-auto p-3">
      <ul class="flex flex-col gap-1" data-results></ul>
      <p class="py-4 text-center text-sm opacity-60" data-empty hidden>
        검색 결과가 없어요.
      </p>
    </div>

    <!-- 하단 힌트 -->
    <div
      class="border-base-300 flex items-center justify-between border-t p-3 text-xs opacity-60"
    >
      <span>ESC 닫기</span>
      <span>↑↓ 탐색 · Enter 이동</span>
      <span class="hidden sm:inline">⌘K / Ctrl+K 열기</span>
    </div>
  </div>

  <!-- daisyUI 배경 클릭 닫기 -->
  <form method="dialog" class="modal-backdrop">
    <button>close</button>
  </form>
</dialog>

<script>
  import './search-modal';
</script>
