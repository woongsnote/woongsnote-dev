---
import { formatDate } from '@/lib/date';
import type { PostEntry } from '@/types';

type Props = {
  post: PostEntry;
  headingLevel?: 'h2' | 'h3';
};

const {
  post: {
    id,
    data: { title, description, publishedDate, category },
  },
  headingLevel: Tag = 'h2',
} = Astro.props;
---

<li>
  <a href={`/${id}`} class="group block break-keep no-underline">
    <div
      class="text-base-content/55 mb-2.5 flex items-center gap-3.5 font-mono text-xs"
    >
      <time datetime={publishedDate.toISOString()}>
        {formatDate(publishedDate)}
      </time>
      <span
        class="relative pl-3.5 tracking-[0.14em] uppercase before:absolute before:top-1/2 before:left-0 before:h-px before:w-1 before:-translate-y-1/2 before:bg-current"
      >
        {category}
      </span>
    </div>
    <Tag
      class="text-base-content group-hover:text-primary mb-1.5 text-base leading-snug font-semibold tracking-tight text-balance transition-colors"
    >
      {title}
    </Tag>
    <p
      class="text-base-content/65 line-clamp-2 text-sm leading-relaxed break-keep"
    >
      {description}
    </p>
  </a>
</li>
