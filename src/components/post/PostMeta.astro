---
import ReadingTimeText from './ReadingTimeText.astro';
import ShareButton from './share/ShareButton.astro';

const { minutesToRead, title, publishedDate, link } = Astro.props;
---

<div class="flex items-center justify-between gap-2 text-sm lg:text-base">
  <div class="text-sub flex gap-2">
    <span>{publishedDate}</span>
    <ReadingTimeText readingTime={minutesToRead} />
  </div>
  <ShareButton title={title} url={link} />
</div>
