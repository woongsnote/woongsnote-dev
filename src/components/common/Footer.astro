---
import { SOCIALS } from '@/config';

const year = new Date().getFullYear();
---

<footer
  class="footer bg-base-200 border-base-content/5 mt-auto border-t px-4 py-5"
>
  <div
    class="mx-auto flex w-full max-w-4xl flex-col-reverse items-center justify-between gap-3.5 font-mono text-xs md:flex-row md:items-baseline"
  >
    <p class="text-base-content/70">
      &copy; {year} woongsnote
    </p>
    <nav aria-label="소셜 링크" class="flex gap-4.5">
      {
        SOCIALS.map(({ title, url }) => {
          return (
            <a
              href={url}
              target="_blank"
              rel="noopener noreferrer"
              class="text-base-content/80 hover:text-base-content no-underline transition-colors duration-200"
              aria-label={`${title} 페이지로 이동`}
            >
              <span>{title}</span>
            </a>
          );
        })
      }
    </nav>
  </div>
</footer>
