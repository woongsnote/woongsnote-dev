---
import SearchButton from '../search/SearchButton.astro';
import ThemeToggle from './ThemeToggle.astro';

const navLinks = [
  { href: '/about', label: 'about' },
  { href: '/archive', label: 'archive' },
] as const;

const linkClass =
  'text-neutral-content hover:text-base-content font-mono text-xs sm:text-sm transition-colors';
---

<header class="bg-base-200 sticky top-0 z-50 h-16">
  <nav class="navbar mx-auto max-w-4xl px-2 lg:px-0">
    <div class="flex-1">
      <a href="/" class="text-base-content text-lg font-bold">woongsnote</a>
    </div>

    <div class="flex items-center gap-2 sm:gap-3">
      {
        navLinks.map(({ href, label }) => (
          <a href={href} class={linkClass}>
            {label}
          </a>
        ))
      }
      <SearchButton />
      <ThemeToggle />
    </div>
  </nav>
</header>
