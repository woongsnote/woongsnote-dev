---
import AboutIcon from '@/shared/assets/icons/about.svg';
import Search from '../search/Search.astro';
import ThemeToggle from './ThemeToggle.astro';
---

<header class="bg-base-200 sticky top-0 z-50 h-16">
  <nav class="navbar mx-auto max-w-4xl">
    <div class="flex-1">
      <a href="/" class="text-base-content text-lg font-bold">woongsnote</a>
    </div>

    <div class="flex items-center gap-1">
      <Search />
      <a
        href="/about"
        class="btn btn-ghost btn-square btn-sm"
        aria-label="소개"
      >
        <AboutIcon />
      </a>
      <ThemeToggle />
    </div>
  </nav>
</header>
