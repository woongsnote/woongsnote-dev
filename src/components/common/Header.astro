---
import Search from '../search/Search.astro';
import ThemeToggle from './ThemeToggle.astro';
---

<header class="bg-base-200 sticky top-0 z-50 h-16">
  <nav class="navbar mx-auto max-w-4xl">
    <div class="flex-1">
      <a href="/" class="text-base-content text-lg font-bold">woongsnote</a>
    </div>

    <nav class="flex items-center gap-3">
      <Search />
      <a
        href="/about"
        class="text-base-content/40 hover:text-base-content font-mono text-sm tracking-wide no-underline transition-colors duration-200"
        >about</a
      >
      <a
        href="/archive"
        class="text-base-content/40 hover:text-base-content font-mono text-sm tracking-wide no-underline transition-colors duration-200"
        >archive</a
      >
      <ThemeToggle />
    </nav>
  </nav>
</header>
