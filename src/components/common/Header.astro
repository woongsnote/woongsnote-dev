---
import SearchButton from '../search/SearchButton.astro';
import ThemeToggle from './ThemeToggle.astro';

const navLinks = [
  { href: '/about', label: 'about' },
  { href: '/archive', label: 'archive' },
] as const;

const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';

const isActivePath = (href: string) => {
  const normalizedHref = href.replace(/\/$/, '') || '/';

  return (
    pathname === normalizedHref || pathname.startsWith(`${normalizedHref}/`)
  );
};

const navLinkBaseClass =
  'focus-ring rounded-sm text-xs font-medium tracking-wide transition-colors sm:text-sm';
---

<header
  class="bg-base-200 border-base-content/5 sticky top-0 z-50 h-16 border-b"
>
  <div class="navbar mx-auto max-w-4xl px-2 lg:px-0">
    <div class="flex-1">
      <a
        href="/"
        class="focus-ring text-base-content hover:text-primary rounded-sm text-lg font-semibold tracking-tight transition-colors"
      >
        woongsnote
      </a>
    </div>

    <div class="flex items-center gap-2 sm:gap-3">
      <nav aria-label="주 메뉴" class="flex items-center gap-4 sm:gap-5">
        {
          navLinks.map(({ href, label }) => {
            const isActive = isActivePath(href);

            return (
              <a
                href={href}
                class:list={[
                  navLinkBaseClass,
                  isActive
                    ? 'text-base-content'
                    : 'text-neutral-content hover:text-base-content',
                ]}
                aria-current={isActive ? 'page' : undefined}
              >
                {label}
              </a>
            );
          })
        }
      </nav>
      <SearchButton />
      <ThemeToggle />
    </div>
  </div>
</header>
