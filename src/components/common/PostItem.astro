---
import { fmtHomeDateShort } from '@/lib/date';
import type { PostEntry } from '@/shared/types';

type Props = {
  post: PostEntry;
};

const { post } = Astro.props;

const href = post.id;

const { title, publishedDate } = post.data;

const date = fmtHomeDateShort(publishedDate);
---

<li class="list-row">
  <a
    href={href}
    class="focus-visible:ring-accent/40 group flex items-center px-4 py-3 transition-colors duration-150 focus-visible:ring-2 focus-visible:outline-none"
  >
    <div class="flex min-w-0 items-center gap-3.5">
      <span class="text-sub w-16 shrink-0 text-xs tabular-nums opacity-50">
        {date}
      </span>
      <span
        class="line-clamp-2 min-w-0 text-base leading-snug font-medium tracking-tight underline-offset-4 group-hover:underline"
      >
        {title}
      </span>
    </div>
  </a>
</li>
