---
import Footer from '@/components/common/Footer.astro';
import Header from '@/components/common/Header.astro';
import SearchModal from '@/components/search/SearchModal.astro';
import { siteConfig } from '@/config';
import '@/styles/global.css';
import type { PageMeta } from '@/types';
import BaseHead from './BaseHead.astro';
import BackToTop from '@/components/common/BackToTop.astro';
import { THEME } from '@/lib/theme';

interface Props extends PageMeta {
  noindex?: boolean;
}

const { title, description, image, articleDate, noindex } = Astro.props;
---

<!doctype html>
<html lang={siteConfig.lang}>
  <head>
    <script is:inline define:vars={{ THEME }}>
      // @ts-nocheck — THEME via define:vars, window flags via global state

      /** localStorage + 시스템 선호도로 적용할 테마 결정 */
      function getTheme() {
        const saved = localStorage.getItem(THEME.storageKey);
        const isLight =
          saved === THEME.light ||
          (!saved && matchMedia('(prefers-color-scheme: light)').matches);

        return isLight ? THEME.light : THEME.dark;
      }

      /** theme 값에 맞는 browser theme-color 반환 */
      function getThemeColor(theme) {
        return theme === THEME.light ? THEME.colors.light : THEME.colors.dark;
      }

      /** 현재 data-theme에 맞춰 browser theme-color 메타 동기화 */
      function syncThemeColor(targetDocument = document) {
        const theme =
          targetDocument.documentElement.getAttribute('data-theme') ??
          getTheme();

        targetDocument
          .querySelector('meta[name="theme-color"]')
          ?.setAttribute('content', getThemeColor(theme));
      }

      /** 부트스트랩: 테마 적용 + 메타 동기화 1회 실행 */
      function applyTheme() {
        document.documentElement.setAttribute('data-theme', getTheme());
        syncThemeColor();
      }

      applyTheme();

      // BaseHead가 뒤에 있어서 첫 실행 때 meta가 없을 수 있으므로 한 번 더 보정
      document.addEventListener('DOMContentLoaded', syncThemeColor, {
        once: true,
      });

      // View Transition 시 새 문서에 미리 테마 + theme-color 적용
      document.addEventListener('astro:before-swap', (event) => {
        const theme = getTheme();

        event.newDocument.documentElement.setAttribute('data-theme', theme);
        syncThemeColor(event.newDocument);
      });

      // data-theme 변경 자동 추적
      if (!window.__themeColorObserverMounted) {
        window.__themeColorObserverMounted = true;

        new MutationObserver(syncThemeColor).observe(document.documentElement, {
          attributes: true,
          attributeFilter: ['data-theme'],
        });
      }
    </script>

    <BaseHead {title} {description} {image} {articleDate} {noindex} />
  </head>
  <body class="flex min-h-dvh flex-col">
    <Header />
    <main class="px-4">
      <slot />
    </main>
    <Footer />
    <SearchModal />
    <BackToTop />
  </body>
</html>
