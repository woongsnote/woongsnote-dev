---
import Footer from '@/components/common/Footer.astro';
import Header from '@/components/common/Header.astro';
import SearchModal from '@/components/search/SearchModal.astro';
import { siteConfig } from '@/config';
import '@/styles/global.css';
import type { PageMeta } from '@/types';
import BaseHead from './BaseHead.astro';
import BackToTop from '@/components/common/BackToTop.astro';
import { THEME } from '@/lib/theme';

interface Props extends PageMeta {
  noindex?: boolean;
}

const { title, description, image, articleDate, noindex } = Astro.props;
---

<!doctype html>
<html lang={siteConfig.lang}>
  <head>
    <script is:inline define:vars={{ THEME }}>
      function getTheme() {
        const saved = localStorage.getItem(THEME.storageKey);
        const isLight =
          saved === THEME.light ||
          (!saved && matchMedia('(prefers-color-scheme: light)').matches);

        return isLight ? THEME.light : THEME.dark;
      }

      function applyTheme() {
        document.documentElement.setAttribute('data-theme', getTheme());
      }

      applyTheme();

      document.addEventListener('astro:before-swap', (event) => {
        event.newDocument.documentElement.setAttribute(
          'data-theme',
          getTheme()
        );
      });
    </script>
    <BaseHead {title} {description} {image} {articleDate} {noindex} />
  </head>
  <body class="flex min-h-dvh flex-col">
    <Header />
    <main class="px-4">
      <slot />
    </main>
    <Footer />
    <SearchModal />
    <BackToTop />
  </body>
</html>
