---
import { getArticleJsonLd, getWebsiteJsonLd, siteConfig } from '@/config';
import type { PageMeta } from '@/types';

interface Props extends PageMeta {
  noindex?: boolean;
}

const { title, description, image, articleDate, noindex } = Astro.props;

const ogImage = image ?? '/opengraph-image.png';
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(ogImage, Astro.site).href;

const pageTitle =
  title === siteConfig.name ? title : `${title} | ${siteConfig.name}`;

const ogLocale = siteConfig.locale.replace('-', '_');

const jsonLd = articleDate
  ? getArticleJsonLd({
      title,
      description,
      url: canonicalURL.href,
      image: ogImageURL,
      datePublished: articleDate,
    })
  : getWebsiteJsonLd();
---

<meta charset="utf-8" />
<meta
  name="viewport"
  content="width=device-width,initial-scale=1,viewport-fit=cover"
/>
<meta
  name="theme-color"
  content="#060709"
  media="(prefers-color-scheme: dark)"
/>
<meta
  name="theme-color"
  content="#f7f9fa"
  media="(prefers-color-scheme: light)"
/>

<link
  rel="preload"
  href="/fonts/WantedSansVariable.woff2"
  as="font"
  type="font/woff2"
  crossorigin
/>
<link rel="icon" type="image/png" href="/favicon.png" />
<link rel="canonical" href={canonicalURL.href} />
<meta name="generator" content={Astro.generator} />

<link rel="sitemap" href="/sitemap-index.xml" />
<link
  rel="alternate"
  type="application/rss+xml"
  title={siteConfig.name}
  href={new URL('rss.xml', Astro.site).href}
/>

<title>{pageTitle}</title>
<meta name="description" content={description} />

<!-- Open Graph -->
<meta property="og:site_name" content={siteConfig.name} />
<meta property="og:type" content={articleDate ? 'article' : 'website'} />
<meta property="og:locale" content={ogLocale} />
<meta property="og:url" content={canonicalURL.href} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImageURL} />
<meta property="og:image:type" content="image/png" />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content={title} />

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageURL} />
<meta name="twitter:image:alt" content={title} />

{
  articleDate && (
    <>
      <meta property="article:published_time" content={articleDate} />
      <meta property="article:author" content={siteConfig.name} />
    </>
  )
}
{noindex && <meta name="robots" content="noindex,nofollow" />}

<script
  is:inline
  type="application/ld+json"
  set:html={JSON.stringify(jsonLd)}
/>
